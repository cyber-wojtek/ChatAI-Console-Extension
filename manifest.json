{
  "manifest_version": 3,
  "name": "ChatAI Console OAuth Bridge",
  "version": "1.2",
  "description": "Intercepts Google OAuth callbacks for Claude and MiniApps, relaying tokens to ChatAI Console on localhost. Disabled by default — enable only when signing in.",

  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://miniapps.ai/*",
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_claude.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://miniapps.ai/*"],
      "js": ["content_miniapps.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatAI Console"
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
